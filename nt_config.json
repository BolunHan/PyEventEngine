{
    "connection": {
        "host": "<windows-vm-ip>",
        "port": 22,
        "user": "<domain>\\<username>",
        "identity_file": "~/.ssh/<keyfile>.pem"
    },
    "windows": {
        "python_path": "C:\\Program Files\\Python313\\python.exe",
        "venv_path": "C:\\Users\\<username>\\Projects\\venv_313",
        "proxy": "<proxy-host>:<proxy-port>"
    },
    "project": {
        "remote_root": "C:\\Users\\<username>\\Projects\\PyEventEngine",
        "local_root": "/home/<username>/Projects/PyEventEngine"
    },
    "sync": {
        "exclude_patterns": [
            ".git",
            "__pycache__",
            "*.pyc",
            ".pytest_cache",
            "*.egg-info",
            "build",
            "event_engine/includes",
            ".idea",
            ".vscode",
            "macros.json",
            "*.so",
            "*.c",
            "*.cpython-*.so"
        ]
    }
}
